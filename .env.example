# Equinox frontend — chain config. Copy to `.env`.
# Wallet connection (RainbowKit/wagmi) is always real. Set VITE_USE_REAL_CHAIN=true
# to also route contract calls on-chain (needs the contracts deployed); leave it
# false to connect a real wallet but simulate protocol actions with mock data.

VITE_USE_REAL_CHAIN=false

# WalletConnect Cloud projectId (required for WalletConnect / mobile wallets).
# Injected wallets like MetaMask work without it. Get one: https://cloud.reown.com
VITE_WC_PROJECT_ID=

# Arbitrum Sepolia RPC
VITE_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Pyth pull-oracle on Arbitrum Sepolia (verify at docs.pyth.network before mainnet)
VITE_PYTH=0x4374e5a8b9C22271E9EB878A2AA31DE97DF15DAF

# Deployed contract addresses (from `forge script script/Deploy.s.sol`)
VITE_EQUINOX_POOL=
VITE_KYC_REGISTRY=
VITE_FHERC20_WRAPPER=

# Block the EquinoxPool was deployed at — bounds the liquidator's event scan
# (eth_getLogs). Leave empty to scan only the most recent ~90k blocks.
VITE_POOL_DEPLOY_BLOCK=

# KYC attester signing service. Returns { expiry, signature } for register().
# For local testing run `ATTESTER_PRIVATE_KEY=0x.. node scripts/attester.mjs`
# (the key's address must equal KYC_ATTESTER used at deploy) and point here:
VITE_KYC_ATTESTER_URL=

# Pyth Hermes price service (live equity prices). Default is Pyth's public host.
VITE_PYTH_HERMES=https://hermes.pyth.network

# Official Circle USDC on Arbitrum Sepolia (verified: symbol=USDC, decimals=6)
VITE_USDC=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Collateral dShare token the pool was deployed against (the `DSHARES` deploy
# arg). For the single-collateral demo this is the dTSLA mock address.
VITE_DSHARES=0x1be207f7ae412c6deb0505485a36bfbdbd921d89

# Mock tokenized-equity basket (from `forge script script/DeployMocks.s.sol`)
VITE_DTSLA=0x1be207f7ae412c6deb0505485a36bfbdbd921d89
VITE_DAAPL=
VITE_DNVDA=
VITE_DMSFT=
VITE_DGOOGL=
VITE_DAMZN=
VITE_DMETA=
VITE_DCOIN=
VITE_DAMD=
VITE_DNFLX=
VITE_DPLTR=
VITE_DINTC=
VITE_DJPM=
VITE_DV=
VITE_DDIS=
VITE_DBA=
VITE_DMSTR=
VITE_DNKE=
