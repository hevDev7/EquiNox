# ============================================================
# Equinox — CONTRACT DEPLOY env (Foundry).  ⚠️ NOT the frontend .env!
#
# Copy to `contracts/.env`, fill it in, then before running forge:
#     cd contracts && source .env
# (forge auto-loads this file for vm.env* vars; PRIVATE_KEY & the RPC are
#  consumed by CLI flags, so you must `source` it so the shell has them.)
#
# 🔐 SECURITY
#   • NEVER commit a real key (this file's sibling `.env` is gitignored).
#   • NEVER put a private key in the FRONTEND root .env — Vite bundles env
#     into the browser bundle. Deploy keys belong ONLY in contracts/.env.
#   • Use a FRESH, throwaway deployer funded with Arbitrum Sepolia test ETH.
#   • Safer (no plaintext key on disk): import once into Foundry's keystore
#       cast wallet import deployer --interactive
#     then deploy with `--account deployer` instead of `--private-key $PRIVATE_KEY`.
# ============================================================

# --- deployer key + RPC (used by the forge CLI flags after `source .env`) ---
PRIVATE_KEY=
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# (optional) Arbiscan API key for `--verify`
ARBISCAN_API_KEY=

# ============================================================
# Role / config vars read by the deploy scripts (vm.env*)
# ============================================================

# --- Deploy.s.sol (DEMO: single-key admin, manual oracle price) ---
# All optional — default to the deployer EOA / Circle USDC.
# NOTE: this script deploys its OWN MockDShares collateral token; use the
# printed "MockDShares" address as VITE_DSHARES in the frontend .env.
GOVERNANCE=
KYC_ATTESTER=
USDC=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# --- DeployProduction.s.sol (timelock + multisig + Pyth adapter) ---
# MULTISIG, PYTH, TSLA_FEED_ID, DSHARES, KYC_ATTESTER are REQUIRED here.
MULTISIG=
TIMELOCK_DELAY=172800
PYTH=0x4374e5a8b9C22271E9EB878A2AA31DE97DF15DAF
TSLA_FEED_ID=0x16dad506d7db8da01c87581c87ca897a012a153557d4d578c3b9c9e1bc0632f1
DSHARES=
